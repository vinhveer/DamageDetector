{
  "name": "damage-detector-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:react": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "lint": "eslint ."
  },
  "dependencies": {
    "@radix-ui/react-switch": "1.1.4",
    "@radix-ui/react-tooltip": "1.1.8",
    "@reduxjs/toolkit": "2.11.2",
    "@tabler/icons-react": "3.42.0",
    "dayjs": "1.11.20",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-redux": "9.2.0",
    "utif": "3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.2.4",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "42.0.0",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "tailwindcss": "4.2.4",
    "vite": "8.0.10",
    "wait-on": "9.0.5"
  }
}
